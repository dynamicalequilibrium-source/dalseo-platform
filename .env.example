# Next.js
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# Database
DATABASE_URL=file:./data/programs.db

# Python Scraper
PYTHON_SCRAPER_INTERVAL=86400 # 24 hours in seconds
SCRAPER_TIMEOUT=30 # seconds per request

# Claude API (for AI classification)
ANTHROPIC_API_KEY=your-api-key-here

# Kakao Bot
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_USER_ID=your-kakao-user-id

# Logging
LOG_LEVEL=info
